<script>
  const zone = document.querySelector<HTMLElement>(".stack-zone");
  const stack = document.querySelector<HTMLElement>("#stack");
  const layerButtons = [
    ...document.querySelectorAll<HTMLButtonElement>("[data-layer]"),
  ];

  layerButtons.forEach((button) =>
    button.addEventListener("click", () => {
      if (!stack || !zone) return;
      const selected = button.dataset.layer ?? "photo";
      const next = stack.dataset.active === selected ? "photo" : selected;
      stack.dataset.active = next;
      layerButtons.forEach((item) =>
        item.setAttribute(
          "aria-pressed",
          String(item.dataset.layer === next),
        ),
      );
      zone.classList.add("touched");
      stack.style.transform = "";
      stack.classList.remove("tilting");
    }),
  );

  const fine = matchMedia("(pointer:fine)").matches;
  const motionOK = matchMedia(
    "(prefers-reduced-motion:no-preference)",
  ).matches;

  if (zone && stack && fine && motionOK) {
    zone.addEventListener("mousemove", (event) => {
      if (stack.dataset.active !== "photo") return;
      const rect = stack.getBoundingClientRect();
      const x = (event.clientX - rect.left) / rect.width - 0.5;
      const y = (event.clientY - rect.top) / rect.height - 0.5;
      stack.style.transform = `rotateY(${x * 10}deg) rotateX(${-y * 8}deg)`;
      stack.classList.add("tilting");
      zone.classList.add("touched");
    });

    zone.addEventListener("mouseleave", () => {
      stack.style.transform = "";
      stack.classList.remove("tilting");
    });
  }
</script>

