<button class="theme-toggle" id="theme-toggle" type="button" aria-label="Switch theme">
  <svg class="sun" viewBox="0 0 24 24" aria-hidden="true">
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path>
  </svg>
  <svg class="moon" viewBox="0 0 24 24" aria-hidden="true">
    <path d="M20 15.5A8.5 8.5 0 0 1 8.5 4 8.5 8.5 0 1 0 20 15.5z"></path>
  </svg>
</button>

<script>
  const themeToggle = document.querySelector<HTMLButtonElement>("#theme-toggle");
  const themeWindow = window as Window & {
    __setTheme?: (theme: "light" | "dark") => void;
  };

  function syncThemeToggle(theme: string) {
    if (!themeToggle) return;
    const nextTheme = theme === "dark" ? "light" : "dark";
    themeToggle.setAttribute("aria-label", `Switch to ${nextTheme} mode`);
    themeToggle.title = `Switch to ${nextTheme} mode`;
  }

  syncThemeToggle(document.documentElement.dataset.theme ?? "light");

  themeToggle?.addEventListener("click", () => {
    const nextTheme =
      document.documentElement.dataset.theme === "dark" ? "light" : "dark";
    themeWindow.__setTheme?.(nextTheme);
  });

  document.addEventListener("themechange", (event) => {
    syncThemeToggle((event as CustomEvent<{ theme: string }>).detail.theme);
  });
</script>

